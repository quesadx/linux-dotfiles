{
  "position": "bottom",
  "height": 30,
  "spacing": 4,
  "modules-left": [
    "sway/workspaces",
    "sway/scratchpad"
  ],
  "modules-center": [
  ],
  "modules-right": [
    "tray",
    "pulseaudio",
    "network",
    "power-profiles-daemon",
    "cpu",
    "memory",
    "temperature",
    "backlight",
    "battery",
    "clock"
  ],

  "sway/scratchpad": {
    "format": "scratchpad {count}",
    "show-empty": false,
    "tooltip": true,
    "tooltip-format": "{app}: {title}"
  },
  "tray": {
    "spacing": 10
  },
  "clock": {
    "format": "{:%H:%M}"
  },
  "cpu": {
    "format": "cpu {usage}%",
    "tooltip": false,
    "on-click": "foot btop"
  },
  "memory": {
    "format": "memory: {}%",
    "on-click": "foot btop"
  },
  "temperature": {
    "critical-threshold": 80,
    "format": "temperature: {temperatureC}°C"
  },
  "backlight": {
    "format": "backlight: {percent}%"
  },
  "battery": {
    "format": "battery: {capacity}%",
    "on-click": "foot auto-cpufreq --stats"
  },
  "power-profiles-daemon": {
    "format": "power: {profile}"
  },
  "network": {
    "format-wifi": "wifi: {essid}",
    "format-ethernet": "eth: {ipaddr}",
    "format-disconnected": "offline",
    "on-click": "foot nmtui"

  },
  "pulseaudio": {
    "format": "speaker: {volume}%",
    "format-bluetooth": "bluetooth: {volume}%",
    "format-bluetooth-muted": "bluetooth: muted",
    "format-muted": "speaker: muted",
    "on-click": "foot pulsemixer"
  }
}